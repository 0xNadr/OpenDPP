# OpenDPP environment variables
# Copy this file to .env and adjust for your environment.
#
# In the dockerized workflow (default), services talk to each other via
# docker network DNS names. You typically only need to override these
# if you're running services outside docker.

# --- API (FastAPI) -----------------------------------------------------------

# Async SQLAlchemy DSN. Inside the docker network, postgres resolves to the
# `postgres` service. For host-side tools, use localhost:5433.
DATABASE_URL=postgresql+asyncpg://opendpp:opendpp@postgres:5432/opendpp

# Verbose errors, auto-reload.
DEBUG=false

# Comma-separated JSON list of allowed CORS origins.
# Default in code already covers localhost:3030.
# CORS_ORIGINS=["http://localhost:3030","https://opendpp.nader.info"]

# --- Web (Next.js) -----------------------------------------------------------

# Browser-visible base URL of this OpenDPP deployment. Used by the landing
# page to mint scannable QR codes that point to this host.
NEXT_PUBLIC_SITE_URL=http://localhost:3030

# Override which Dockerfile stages to use. Default is `dev` (hot reload, bind
# mounts). Set to `prod` to run the built images locally.
# API_TARGET=dev
# WEB_TARGET=dev

# --- LLM layer (Phase 3) ----------------------------------------------------

# Which ChatProvider to use. 'anthropic' for real Claude calls, 'mock' for
# canned responses (useful for CI / no-key local dev). If 'anthropic' is set
# but ANTHROPIC_API_KEY is empty, the API silently falls back to 'mock'.
LLM_PROVIDER=anthropic

# Anthropic API key. Required for live LLM calls. Never commit this.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Override the default model id if needed.
# ANTHROPIC_MODEL=claude-sonnet-4-6
